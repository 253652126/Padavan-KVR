--- a/src/threadpool/threadpool.c
+++ b/src/threadpool/threadpool.c
@@ -530,27 +530,29 @@
 }
 
 #if defined(__linux__) && !defined(THREAD_NO_PIDFD)
+#ifdef SYS_pidfd_open
 static int
 pidfd_open(pid_t pid, unsigned int flags) {
 	return syscall(SYS_pidfd_open, pid, flags);
 }
+#endif
 
 static int
 thread_wait_by_pidfd(thread_info_t *ti) {
 	if (ti->tid <= 0) {
 		return (-1);
 	}
+#ifdef SYS_pidfd_open
 	ti->pidfd = pidfd_open(ti->tid, 0);
 	if (ti->pidfd < 0) {
 		return (-1);
 	}
 	return (0);
+#else
+	return (-1);
+#endif
 }
 #endif
 
 static int
 thread_wait(thread_info_t *ti) {
 #if defined(__linux__) && !defined(THREAD_NO_PIDFD)
+#ifdef SYS_pidfd_open
 	if (thread_wait_by_pidfd(ti) == 0) {
 		return (0);
 	}
+#endif
 #endif
 	/* Fallback to pipe-based waiting */
 	return (thread_wait_by_pipe(ti));
 }
